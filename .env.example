# CarCatcher configuration. Copy to .env and fill in real values (.env is gitignored).

# --- Core ---
APP_NAME=CarCatcher
BASE_URL=https://carcatcher.jurtin.de
# Inside the api container this is /data/db/carcatcher.db (NFS bind-mount).
DATABASE_PATH=/data/db/carcatcher.db

# Host directory bind-mounted to /data in the api container (NFS mount in prod).
DATA_DIR=/mnt/carcatcher
# Port the ui (nginx) container exposes on the LXC; shared nginx proxies here.
UI_PORT=8080

# --- Firecrawl (self-hosted) ---
FIRECRAWL_BASE_URL=http://firecrawl-api:3002
FIRECRAWL_API_KEY=
FIRECRAWL_IMAGE=ghcr.io/firecrawl/firecrawl:latest
PLAYWRIGHT_IMAGE=ghcr.io/firecrawl/playwright-service:latest
FIRECRAWL_CONCURRENCY=2
SCRAPE_MIN_INTERVAL_MS=1500
DETAIL_TTL_HOURS=24
SEARCH_MAX_PAGES=5

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
AI_DISABLED=false
AI_MONTHLY_BUDGET_USD=25
HAIKU_CONCURRENCY=5

# --- Scoring ---
MIN_COMPS=5
DEAL_THRESHOLD=0.08
MAX_SONNET_EVALS_PER_RUN=30

# --- Scheduler / snapshot ---
# Comma-separated sources crawled each run (registered scrapers).
CRAWL_SOURCES=kleinanzeigen,autoscout24,mobilede
# cron expression (every 3 hours by default)
CRON_SCHEDULE=0 */3 * * *
# protects POST /api/refresh — set to a long random string
CRON_SECRET=change-me-to-a-long-random-string
RUN_TIMEOUT_MINUTES=30
PRUNE_GONE_DAYS=14
